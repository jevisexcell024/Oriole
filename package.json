{
  "name": "orcalis-v2",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "scripts": {
    "dev": "concurrently -k -n web,api -c cyan,magenta \"vite\" \"tsx watch --env-file-if-exists=.env server/index.ts\"",
    "dev:api": "tsx watch --env-file-if-exists=.env server/index.ts",
    "dev:web": "vite",
    "build": "tsc -b && vite build",
    "build:server": "esbuild server/index.ts --bundle --platform=node --format=esm --target=node18 --outfile=dist-server/server.mjs --packages=external",
    "build:restore": "esbuild scripts/restore-backup.mjs --bundle --platform=node --format=esm --target=node18 --outfile=dist-server/restore-backup.mjs --packages=external",
    "build:cpanel": "npm run build && npm run build:server",
    "start": "tsx --env-file-if-exists=.env server/index.ts",
    "start:bundle": "node --env-file-if-exists=.env dist-server/server.mjs",
    "preview": "vite preview",
    "seed": "tsx server/seed.ts",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "loadtest": "node scripts/load-test.mjs",
    "deploy:zip": "npm run build:cpanel && powershell -ExecutionPolicy Bypass -File scripts/package-deploy.ps1"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.2",
    "@electric-sql/pglite": "^0.5.1",
    "@monaco-editor/react": "^4.7.0",
    "@types/katex": "^0.16.8",
    "@types/leaflet": "^1.9.21",
    "@types/nodemailer": "^8.0.1",
    "@types/qrcode": "^1.5.6",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "katex": "^0.17.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.468.0",
    "mammoth": "^1.12.0",
    "nanoid": "^5.0.9",
    "nodemailer": "^9.0.1",
    "pdf-lib": "^1.17.1",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.1.1",
    "recharts": "^3.9.0",
    "tsx": "^4.19.2",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "esbuild": "^0.28.0",
    "pino-pretty": "^13.1.3",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "dompurify": "^3.4.11"
  }
}
