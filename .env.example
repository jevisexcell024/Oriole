# ─── Orcalis Assess — environment ───────────────────────────────────────────
# Copy to `.env` for local overrides, or set these in your hosting provider.
# In production the server REFUSES TO START unless JWT_SECRET, DATABASE_URL and
# DATA_ENCRYPTION_KEY are set (see server/env.ts).

NODE_ENV=development
API_PORT=8787

# Session signing key. Generate: `node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"`
JWT_SECRET=

# Managed Postgres connection string. When unset, the server falls back to an
# embedded PGlite file under server/.pgdata (local dev / tests only).
# DATABASE_URL=postgres://user:pass@host:5432/orcalis
# DATABASE_POOL_MAX=10
# DATABASE_SSL=true

# AES-256-GCM key for encrypting proctoring media / PII at rest (base64, 32 bytes).
# Generate: `node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"`
# DATA_ENCRYPTION_KEY=

# Purge proctoring webcam frames older than N days (0 = keep indefinitely).
PROCTOR_RETENTION_DAYS=0

# Logging / limits
LOG_LEVEL=debug
API_RATE_LIMIT=600

# Email (optional). MAIL_TRANSPORT=smtp enables real delivery; otherwise a
# mock/preview transport is used and messages are logged.
# MAIL_TRANSPORT=smtp
# MAIL_FROM="Orcalis Assess <no-reply@orcalis.dev>"
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=

# SMS / WhatsApp reminders (optional). SMS_PROVIDER=twilio enables real delivery.
# SMS_PROVIDER=twilio
# SMS_CHANNEL=sms            # or "whatsapp"
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=+14155551234
# TWILIO_WHATSAPP_FROM=

# Microsoft (Entra / Microsoft 365) SSO (optional). When set, a "Sign in with
# Microsoft" button appears on the login page; SSO only signs in users that already
# exist in Orcalis (matched by email). Register the redirect URI in your Entra app:
#   https://YOUR-DOMAIN/api/auth/sso/microsoft/callback
# MS_CLIENT_ID=
# MS_CLIENT_SECRET=
# MS_TENANT=organizations    # or your specific tenant ID to lock to your org
# MS_REDIRECT_URI=           # optional; otherwise derived from the request host

# AI features (optional) — OpenAI-compatible (Groq/Gemini/OpenRouter) or Anthropic.
# AI_BASE_URL=
# AI_API_KEY=
# AI_MODEL=
# ANTHROPIC_API_KEY=
# ORCALIS_AI_MODEL=claude-opus-4-8
